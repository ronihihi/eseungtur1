# ─── E-Sign Workflow — Environment Variables ───────────────
# Copy this file to .env and fill in your values

# Session secret (change to a long random string in production)
SESSION_SECRET=change-this-to-a-random-secret-string

# ── Email (SMTP) Settings ───────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# For SendGrid (alternative):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Server port (Replit uses 3000)
PORT=3000
